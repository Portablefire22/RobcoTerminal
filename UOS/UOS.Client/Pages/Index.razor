@page "/"
@using UOS.Client.Types.Enums
@inject HttpClient HttpClient;
@inject IJSRuntime JSRuntime;
@rendermode InteractiveWebAssembly

<PageTitle>RobCo Industries Unified Operating System</PageTitle>

@if (!RendererInfo.IsInteractive) return;

<div class="robco-main" @ref="@MainRef" tabindex="0" @onkeydown="@KeyDown">
    <HeaderComponent @bind-Finished="HeaderFinished"/>
    <div class="robco-content">
    @if (HeaderFinished)
    {
        @switch (State)
        {
            case 0:
                <MainMenu KeyboardEventArgs="@KeyboardEventArgs" @bind-State="@State"/>
                break;
            default:
                @if (Text != "")
                {
                    <DataCorruptionComponent ErrorCode="TerminalError.MemoryFault" Text="@Text"/>
                }
                break;
        }
    }
    </div>
</div>
    
@code {

    public int State
    {
        get;
        set;
    } = 0;

    private ElementReference MainRef { get; set; }
    
    public bool HeaderFinished { get; set; } = false;

    private KeyboardEventArgs KeyboardEventArgs { get; set; } = new KeyboardEventArgs();
    
    public string Text { get; set; } = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            await JSRuntime.InvokeVoidAsync("SetFocusToElement", MainRef);
            return;
        };

        Text = await HttpClient.GetStringAsync("/text/mainMenuCorrupted.txt");
        await InvokeAsync(StateHasChanged);
    }

   
    protected void KeyDown(KeyboardEventArgs e)
    {
        KeyboardEventArgs = e; 
        StateHasChanged();
    }

}